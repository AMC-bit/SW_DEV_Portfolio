<Window x:Class="WPFClientProgettoAnagrafiche.Views.Windows.ContattoEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Contatto"
        WindowStartupLocation="CenterScreen"
        Width="550"
        Height="800"
        ResizeMode="CanResize"
        Background="White">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"/>

            <!-- Type Selection -->
            <GroupBox Header="Tipo Anagrafica" Margin="0,0,0,15" IsEnabled="{Binding IsNewContatto}">
                <StackPanel Margin="10">
                    <RadioButton Name="PersonaFisicaRadio" 
                                 Content="Persona Fisica" 
                                 IsChecked="{Binding IsPersonaFisica}"
                                 Margin="0,0,0,8"/>
                    <RadioButton Name="PersonaGiuridicaRadio" 
                                 Content="Persona Giuridica" 
                                 IsChecked="{Binding IsPersonaGiuridica}"
                                 Margin="0,0,0,8"/>
                </StackPanel>
            </GroupBox>

            <!-- Name Fields (conditional) -->
            <TextBlock Text="Nome" FontWeight="Bold" Margin="0,0,0,5" 
                       Visibility="{Binding IsPersonaFisica, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15" 
                     Padding="8"
                     Visibility="{Binding IsPersonaFisica, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <TextBlock Text="Cognome" FontWeight="Bold" Margin="0,0,0,5" 
                       Visibility="{Binding IsPersonaFisica, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBox Text="{Binding Cognome, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15" 
                     Padding="8"
                     Visibility="{Binding IsPersonaFisica, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Ragione Sociale (conditional) -->
            <TextBlock Text="Ragione Sociale" FontWeight="Bold" Margin="0,0,0,5" 
                       Visibility="{Binding IsPersonaGiuridica, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBox Text="{Binding RagioneSociale, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15" 
                     Padding="8"
                     Visibility="{Binding IsPersonaGiuridica, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Email -->
            <TextBlock Text="Email" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15" 
                     Padding="8"/>

            <!-- Telefono -->
            <TextBlock Text="Telefono" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15" 
                     Padding="8"/>

            <TextBlock Text="Codice Fiscale" 
  FontWeight="Bold" 
  Margin="0,0,0,5"
  Visibility="{Binding IsPersonaFisica, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <TextBox Text="{Binding CodiceFiscale, UpdateSourceTrigger=PropertyChanged}" 
Margin="0,0,0,15" 
Padding="8"
Visibility="{Binding IsPersonaFisica, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Partita IVA -->
            <TextBlock Text="Partita IVA" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding PartitaIva, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15" 
                     Padding="8"/>

            <!-- Provenienza -->
            <TextBlock Text="Provenienza" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox SelectedItem="{Binding Provenienza, UpdateSourceTrigger=PropertyChanged}" 
                      ItemsSource="{Binding ProvenienzaOptionsList}"
                      Margin="0,0,0,15" 
                      Padding="8"/>

            <!-- Note -->
            <TextBlock Text="Note" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,15" 
                     Padding="8" 
                     Height="80" 
                     TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" 
                     AcceptsReturn="True"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Annulla" 
                        Width="100" 
                        Padding="8" 
                        Margin="0,0,10,0" 
                        Background="#F0F0F0" 
                        Click="CancelButton_Click"/>
                <Button Content="Salva" 
                        Width="100" 
                        Padding="8" 
                        Background="#007ACC" 
                        Foreground="White" 
                        Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>