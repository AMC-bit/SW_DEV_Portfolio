<Page x:Class="WPFClientProgettoAnagrafiche.Views.Pages.RicercaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ricerca" Background="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Ricerca" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>



            <!-- Search Box 1 -->
            <TextBlock Text="Search Filters" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Nome" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchNome, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" BorderThickness="1" BorderBrush="#CCCCCC"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Cognome" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchCognome, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" BorderThickness="1" BorderBrush="#CCCCCC"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Email" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchEmail, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" BorderThickness="1" BorderBrush="#CCCCCC"/>
                </StackPanel>
            </Grid>

            <!-- Search Box 2 -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Codice Fiscale" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchCodiceFiscale, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" BorderThickness="1" BorderBrush="#CCCCCC"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Partita IVA" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchPartitaIva, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" BorderThickness="1" BorderBrush="#CCCCCC"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Ragione Sociale" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchRagioneSociale, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" BorderThickness="1" BorderBrush="#CCCCCC"/>
                </StackPanel>
            </Grid>

            <!-- Clear Button -->
            <Button Content="Pulisci Filtri" 
                    Command="{Binding ClearFiltersCommand}" 
                    Background="#6C757D" 
                    Foreground="White" 
                    Padding="12,8" 
                    FontSize="12" 
                    Cursor="Hand"
                    Width="150"
                    Margin="0,0,0,15"/>

            <!-- Results Table -->
            <!-- Status Messages -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="{Binding StatusText}" Margin="0,0,10,0" Foreground="#666" FontSize="12"/>
                <TextBlock Text="{Binding SuccessMessage}" Margin="0,0,10,0" Foreground="Green" FontSize="12"/>
                <TextBlock Text="{Binding ErrorMessage}" Margin="0,0,0,0" Foreground="Red" FontSize="12"/>
            </StackPanel>

            <DataGrid ItemsSource="{Binding FilteredAnagrafiche}" 
                      SelectedItem="{Binding SelectedAnagrafica}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="80"/>
                    <DataGridTextColumn Header="Nome/Ragione Sociale" Binding="{Binding DisplayName}" Width="200"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                    <DataGridTextColumn Header="Telefono" Binding="{Binding Telefono}" Width="120"/>
                    <DataGridTextColumn Header="Codice Fiscale" Binding="{Binding CodiceFiscale}" Width="120"/>
                    <DataGridTextColumn Header="Partita IVA" Binding="{Binding PartitaIva}" Width="120"/>
                    <DataGridTextColumn Header="Data Reg." Binding="{Binding DataRegistrazione, StringFormat=d}" Width="100"/>
                    <DataGridTextColumn Header="Provenienza" Binding="{Binding Provenienza}" Width="120"/>
                    <DataGridTextColumn Header="Note Contatto" Binding="{Binding NoteContatto}" Width="150"/>
                    <DataGridTextColumn Header="Note Cliente" Binding="{Binding NoteCliente}" Width="150"/>
                    <DataGridTemplateColumn Header="Azioni" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Apri Anagrafica" 
                                        Command="{Binding DataContext.EditAnagraficaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="#0D6EFD"
                                        Foreground="White"
                                        Padding="8,4"
                                        FontSize="11"
                                        Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>
    </ScrollViewer>
</Page>