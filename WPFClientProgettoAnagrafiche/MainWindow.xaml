<Window x:Class="WPFClientProgettoAnagrafiche.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My App" Height="600" Width="1000"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Left Sidebar -->
        <StackPanel Grid.Column="0" Background="White" VerticalAlignment="Stretch">
            <TextBlock Text="My App" FontSize="18" FontWeight="Bold" Margin="15,20"/>
            <Button Content="🏠 Home" 
                    Click="NavigateHome" 
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="❇️ Contatti" 
                    Click="NavigateContatti" 
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="❇️ Clienti" 
         Click="NavigateClienti" 
         Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="❇️ Ricerca" 
         Click="NavigateRicerca" 
         Style="{StaticResource MenuButtonStyle}"/>
        </StackPanel>
        <!-- Content Area -->
        <Frame Grid.Column="1" x:Name="ContentFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>